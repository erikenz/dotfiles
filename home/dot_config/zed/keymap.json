// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
//
// This copies mappings from Astronvim's keymap
[
	{
		"context": "Workspace",
		"bindings": {
			"ctrl-h": "workspace::ActivatePaneLeft",
			"ctrl-j": "workspace::ActivatePaneDown",
			"ctrl-k": "workspace::ActivatePaneUp",
			"ctrl-l": "workspace::ActivatePaneRight"
		}
	},
	{
		"context": "Editor",
		"bindings": {
			"ctrl-[": "pane::ActivatePreviousItem",
			"ctrl-]": "pane::ActivateNextItem",
			"ctrl-g s": "git::StageAndNext",
			"ctrl-g r": "git::Restore",
			"ctrl-g u": "git::UnstageAndNext",
			"ctrl-g a": "git::StageAll",
			"ctrl-g u a": "git::UnstageAll",
			"ctrl-g c": "git::Commit",
			"ctrl-g p": "git::Push",
			"ctrl-g m": "git::GenerateCommitMessage",
			"ctrl-g l": "git::Pull",
			"ctrl-g d d": "git::Diff",
			"ctrl-g d a": "git::Amend",
			"ctrl-g d b": "git::Blame",
			// Resize
			"ctrl-left": "vim::ResizePaneLeft",
			"ctrl-right": "vim::ResizePaneRight",
			"ctrl-up": "vim::ResizePaneUp",
			"ctrl-down": "vim::ResizePaneDown",
			// Navigation
			"ctrl-h": "workspace::ActivatePaneLeft",
			"ctrl-j": "workspace::ActivatePaneDown",
			"ctrl-k": "workspace::ActivatePaneUp",
			"ctrl-l": "workspace::ActivatePaneRight",
			// Buffers
			"ctrl-s": "workspace::Save",
			"ctrl-q": "pane::CloseActiveItem"
		}
	},
	{
		"context": "Editor && vim_mode == normal && vim_operator == none && !VimWaiting",
		"bindings": {
			"space n": "project_panel::NewFile",
			"space R": "project_panel::Rename",
			"space c": "pane::CloseActiveItem",
			"\\": "pane::SplitHorizontal",
			"|": "pane::SplitVertical",
			"space b b": "file_finder::Toggle",
			"space b c": "pane::CloseOtherItems",
			"space b C": "pane::CloseAllItems",
			"space b l": "pane::CloseItemsToTheLeft",
			"space b p": "pane::GoBack",
			"space b r": "pane::CloseItemsToTheRight",
			"space b \\": "workspace::NewFileSplitHorizontal",
			"space b |": "workspace::NewFileSplitVertical",
			"space /": "editor::ToggleComments",
			"space x q": "editor::ToggleCodeActions",
			"space i": "vim::Increment",

			"space e": "project_panel::ToggleFocus",
			"space g": "git_panel::ToggleFocus",
			"space o": "outline_panel::ToggleFocus",
			"space d": "diagnostics::Deploy",
			"space space": "file_finder::Toggle",
			"space a i": "assistant::InlineAssist",
			"space a d": "agent::OpenAgentDiff",
			"space a t": "agent::ToggleFocus",
			"space t": "terminal_panel::ToggleFocus",
			"space u n": "workspace::ClearAllNotifications",
			"space u b": "git::Blame",
			"space g g": [
				"task::Spawn",
				{ "task_name": "Lazygit", "reveal_target": "center" }
			],
			"-": ["task::Spawn", { "task_name": "Yazi", "reveal_target": "center" }],
			"space f f": [
				"task::Spawn",
				{ "task_name": "File Finder", "reveal_target": "center" }
			],
			"space f d": [
				"task::Spawn",
				{ "task_name": "Find Directories", "reveal_target": "center" }
			],
			"space s g": [
				"task::Spawn",
				{ "task_name": "Find in Files", "reveal_target": "center" }
			],
			"space o s": [
				"task::Spawn",
				{ "task_name": "Obsidian", "reveal_target": "center" }
			],
			"space tab a": "tab_switcher::ToggleAll"
		}
	},
	{
		"context": "vim_mode == insert",
		"bindings": {
			"j k": "vim::NormalBefore" // In insert mode, make jk escape to normal mode.
		}
	},
	{
		"context": "Editor && vim_mode == visual && !VimWaiting",
		"bindings": {
			"space a i": "assistant::InlineAssist",
			"space /": "editor::ToggleComments"
		}
	},
	{
		"context": "Terminal",
		"bindings": {
			"ctrl-k": "workspace::ToggleBottomDock",
			"ctrl-shift-f": "workspace::ToggleZoom",
			"ctrl-shift-n": "workspace::NewTerminal"
		}
	},
	{
		"context": "(EmptyPane || SharedScreen)",
		"bindings": {
			"space e": "project_panel::ToggleFocus",
			"space space": "file_finder::Toggle"
		}
	},
	{
		"context": "ProjectPanel && not_editing",
		"bindings": {
			"r": "project_panel::Rename",
			"l": "project_panel::Open",
			"a": "project_panel::NewFile",
			"shift-a": "project_panel::NewDirectory",
			"m": "project_panel::Cut",
			"y": "project_panel::Copy",
			"shift-y": "project_panel::Duplicate",
			"p": "project_panel::Paste",
			"h": "project_panel::CollapseSelectedEntry",
			"d": "project_panel::Trash",
			"shift-d": "project_panel::Delete"
		}
	}
]
