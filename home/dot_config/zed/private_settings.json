// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "which_key": {
    "enabled": true
  },
  "proxy": "",
  "preview_tabs": {
    "enable_preview_multibuffer_from_code_navigation": true,
    "enable_preview_from_file_finder": true
  },
  "title_bar": {
    "show_branch_status_icon": true
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "agent_servers": {
    "gemini": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
    "opencode": {
      "favorite_config_option_values": {
        "model": ["opencode/big-pickle", "opencode/minimax-m2.5-free", "opencode/nemotron-3-super-free", "opencode/qwen3.6-plus-free"],
      },
      "favorite_models": [
        "opencode/big-pickle",
        "opencode/minimax-m2.5-free",
        "opencode/mimo-v2-pro-free",
        "opencode/mimo-v2-omni-free",
        "opencode/nemotron-3-super-free",
      ],
      "type": "registry",
    },
  },
  "git_panel": {
    "show_count_badge": true,
    "file_icons": true,
    "dock": "right",
    "tree_view": true,
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "context_servers": {
    "mcp-server-playwright": {
      "enabled": false,
      "remote": false,
      "settings": {
        "browser": "chromium",
        "headless": false,
        "vision": false,
      },
    },
    "bun-docs-mcp": {
      "enabled": true,
      "remote": false,
      "settings": {},
    },
    "chrome-devtools-mcp-zed": {
      "enabled": true,
      "remote": false,
      "settings": {
        "executable_path": null,
        "browser_url": "http://127.0.0.1:9222",
      },
    },
    "balcon-padel-mcp-server": {
      "enabled": true,
      "command": "npx",
      "args": ["-y", "mcp-remote", "http://localhost:3000/api/mcp", "--header", "Authorization:Bearer ${AUTH_HEADER}"],
      "env": {},
    },
    "balcon-padel-mcp-server-prod": {
      "enabled": true,
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://balconpadel.vercel.app/api/mcp", "--header", "Authorization:Bearer ${AUTH_HEADER}"],
      "env": {},
    },
    // "mercadopago-mcp-server": {
    //   "command": "npx",
    //   "args": ["-y", "mcp-remote", "https://mcp.mercadopago.com/mcp", "--header", "Authorization:Bearer ${AUTH_HEADER}"],
    //   "env": {},
    // },
    "next-devtools": {
      "command": "npx",
      "args": ["-y", "next-devtools-mcp@latest"],
    },
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "base_keymap": "VSCode",
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
  },
  "ui_font_size": 14,
  "buffer_font_size": 12,
  "theme": "Catppuccin",
  "relative_line_numbers": "enabled",
  "terminal": {
    "copy_on_select": true,
    "font_size": 12,
    "dock": "bottom",
    "shell": {
      "program": "/usr/bin/fish",
    },
  },
  "soft_wrap": "bounded",
  "preferred_line_length": 140,
  "project_panel": {
    "git_status_indicator": true,
    "diagnostic_badges": true,
    "bold_folder_labels": false,
    "entry_spacing": "standard",
    "dock": "right",
    "auto_fold_dirs": false,
  },
  "indent_guides": {
    "background_coloring": "indent_aware",
    "enabled": true,
    "coloring": "indent_aware",
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": false,
    },
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "all",
  },
  "outline_panel": {
    "dock": "right",
  },
  "agent": {
    "use_modifier_to_send": true,
    "play_sound_when_agent_done": "always",
    "dock": "left",
    "favorite_models": [
      {
        "provider": "vercel",
        "model": "v0-1.5-md",
        "enable_thinking": false,
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5.2",
        "enable_thinking": false,
      },
      {
        "provider": "copilot_chat",
        "model": "gemini-3.1-pro-preview",
        "enable_thinking": false,
      },
    ],
    "tool_permissions": {
      "default": "allow",
    },
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1",
    },
    "default_profile": "write",
    "commit_message_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
    },
    "default_model": {
      "effort": "high",
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
    },
  },
  "language_models": {
    "openai": {
      "api_url": "https://api.v0.dev/v1",
    },
  },
  "auto_install_extensions": {
    "comment": true,
    "biome": true,
    "dockerfile": true,
    "git-firefly": true,
    "html": true,
    "scss": true,
    "toml": true,
    "lua": true,
  },
  "theme_overrides": {
    "Catppuccin": {
      "syntax": {
        "constant.comment.todo": {
          "color": "#4078f2ff",
          // "background_color": "#00000000",
          // "font_weight": "bold",
          // "font_style": "italic"
        },
        "string.comment.info": {
          "color": "#50a14fff",
          // "background_color": "#00000000",
          // "font_weight": "bold",
          // "font_style": "italic"
        },
        "keyword.comment.warn": {
          "color": "#c18401ff",
          // "background_color": "#00000000",
          // "font_weight": "bold",
          // "font_style": "italic"
        },
        "property.comment.error": {
          "color": "#ca1243ff",
          // "background_color": "#00000000",
          // "font_weight": "bold",
          // "font_style": "italic"
        },
      },
    },
  },
  "languages": {
    "JavaScript": {
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
    },
    "TypeScript": {
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
    },
    "TSX": {
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
    },
    "CSS": {
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
      },
    },
    "SCSS": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
    },
  },
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "classFunctions": ["cva", "cx"],
        "experimental": {
          "classRegex": ["[cls|className]\\s\\:\\=\\s\"([^\"]*)", "tw=\"([^\"]*)\"", "tw='([^']*)'", "tw\\=\\('([^']*)'\\)"],
        },
      },
    },
    "vtsls": {
      "settings": {
        "typescript": {
          "preferences": {
            "importModuleSpecifier": "non-relative",
          },
        },
      },
    },
    "some-sass-lsp": {
      "settings": {
        "somesass": {
          "scss": {
            "completion": {
              "enabled": false,
            },
            "hover": {
              "documentation": false,
              "references": false,
            },
          },
        },
      },
    },

    // scss-lsp / vscode-css-languageserver: safe settings for the core scss server
    "scss-lsp": {
      "settings": {
        "scss": {
          "validate": false,
          "lint": {},
        },
      },
    },

    // fallback key sometimes used by the extension
    // "vscode-css-languageserver": {
    //   "settings": {
    //     "scss": {
    //       "validate": false,
    //       "lint": {},
    //     },
    //   },
    // },
  },
}
