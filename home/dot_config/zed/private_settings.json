// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "diff_view_style": "unified",
  "cli_default_open_behavior": "new_window",
  "language_models": {
    "opencode": {
      "show_zen_models": true,
    },
  },
  "which_key": {
    "enabled": true,
    "delay_ms": 500,
  },
  "icon_theme": "Catppuccin Macchiato",
  "context_servers": {
    "sentry": {
      "url": "https://mcp.sentry.dev/mcp",
    },
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"],
    },
    "next-devtools": {
      "command": "npx",
      "args": ["-y", "next-devtools-mcp@latest"],
    },
    "mcp-server-playwright": {
      "enabled": true,
      "remote": false,
      "settings": {
        "browser": "chromium",
        "headless": false,
        "cdp_endpoint": "http://localhost:9222",
      },
    },
    "balcon-padel-mcp-server": {
      "enabled": true,
      "command": "npx",
      "args": ["-y", "mcp-remote", "http://localhost:3000/api/mcp", "--header", "Authorization:Bearer ${AUTH_HEADER}"],
      "env": {},
    },
    "ultracite": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://docs.ultracite.ai/mcp"],
    },
    "chrome-devtools-mcp-zed": {
      "enabled": true,
      "remote": false,
      "settings": {
        "browser_url": "http://localhost:9222",
        "ws_endpoint": null,
        "ws_headers": null,
        "auto_connect": null,
        "channel": null,
        "headless": null,
        "isolated": null,
        "user_data_dir": null,
        "viewport": null,
        "executable_path": null,
        "chrome_arg": [],
        "proxy_server": null,
        "accept_insecure_certs": null,
        "category_emulation": null,
        "category_performance": null,
        "category_network": null,
        "log_file": null,
        "extra_args": [],
      },
    },
  },
  "agent_servers": {
    "codex-acp": {
      "default_config_options": {
        "model": "gpt-5.5"
      },
      "type": "registry"
    },
    "opencode": {
      "default_config_options": {
        "effort": "low",
        "model": "opencode/big-pickle",
        "mode": "build",
      },
      "favorite_config_option_values": {
        "model": [
          "opencode/big-pickle",
          "opencode/minimax-m3-free",
          "opencode/nemotron-3-ultra-free",
          "opencode/mimo-v2.5-free",
          "opencode/deepseek-v4-flash-free",
          "google/gemini-3.5-flash",
        ],
      },
      "type": "registry",
    },
    "github-copilot-cli": {
      "default_config_options": {
        "allow_all": "on",
        "model": "gemini-3.1-pro-preview",
      },
      "type": "registry",
    },
  },
  "vim_mode": true,
  "theme": {
    "mode": "system",
    "light": "Noctalia Light",
    "dark": "Noctalia Dark",
  },
  "colorize_brackets": true,
  "preview_tabs": {
    "enable_preview_multibuffer_from_code_navigation": true,
    "enable_preview_from_file_finder": true,
  },
  "title_bar": {
    "show_branch_status_icon": true,
  },
  "git_panel": {
    "show_count_badge": true,
    "file_icons": true,
    "dock": "right",
    "tree_view": true,
  },
  "edit_predictions": {
    "provider": "zed",
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
  },
  "soft_wrap": "bounded",
  "preferred_line_length": 140,
  "ui_font_size": 14,
  "buffer_font_size": 12,
  "terminal": {
    "copy_on_select": true,
    "font_size": 12,
    "dock": "bottom",
    "shell": {
      "program": "/usr/bin/fish",
    },
  },
  "project_panel": {
    "git_status_indicator": true,
    "diagnostic_badges": true,
    "bold_folder_labels": false,
    "entry_spacing": "standard",
    "dock": "right",
    "auto_fold_dirs": false,
  },
  "indent_guides": {
    "background_coloring": "indent_aware",
    "enabled": true,
    "coloring": "indent_aware",
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": false,
    },
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "all",
  },
  "agent": {
    "favorite_models": [
      {
        "provider": "opencode",
        "model": "free/big-pickle",
        "enable_thinking": false
      }
    ],
    "use_modifier_to_send": true,
    "play_sound_when_agent_done": "always",
    "tool_permissions": {
      "default": "allow",
    },
    "inline_assistant_model": {
      "provider": "google",
      "model": "gemini-3-flash-preview",
    },
    "default_profile": "write",
    "default_model": {
      "enable_thinking": false,
      "provider": "zed.dev",
      "model": "gpt-5.2",
    },
    "thread_summary_model": {
      "provider": "google",
      "model": "gemini-3-flash-preview",
    },
    "commit_message_model": {
      "provider": "google",
      "model": "gemini-2.5-flash",
    },
  },
  "auto_install_extensions": {
    "comment": true,
    "biome": true,
    "dockerfile": true,
    "git-firefly": true,
    "html": true,
    "scss": true,
    "toml": true,
    "lua": true,
  },
  "file_types": {
    "Hyprland Config": ["hyprland.conf", "hyprlandd.conf", "hyprland.hl", "hyprlandd.hl"],
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"],
  },
  "languages": {
    "JavaScript": {
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
    },
    "TypeScript": {
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
    },
    "TSX": {
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
    },
    "CSS": {
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
      },
    },
    "SCSS": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
    },
    "Lua": {
      "language_servers": ["lua-language-server"]
    }
  },
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "classFunctions": ["cva", "cx"],
        "classAttributes": ["class", "className", "ngClass", "styles"],
        "experimental": {
          "classRegex": ["[cls|className]\\s\\:\\=\\s\"([^\"]*)", "tw=\"([^\"]*)\"", "tw='([^']*)'", "tw\\=\\('([^']*)'\\)"],
        },
      },
    },
    "vtsls": {
      "settings": {
        "typescript": {
          "preferences": {
            "importModuleSpecifier": "non-relative",
          },
        },
      },
    },
    "some-sass-lsp": {
      "settings": {
        "somesass": {
          "scss": {
            "completion": {
              "enabled": false,
            },
            "hover": {
              "documentation": false,
              "references": false,
            },
          },
        },
      },
    },

    // scss-lsp / vscode-css-languageserver: safe settings for the core scss server
    "scss-lsp": {
      "settings": {
        "scss": {
          "validate": false,
          "lint": {},
        },
      },
    },
  },
}
