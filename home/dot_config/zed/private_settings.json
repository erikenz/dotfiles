{
	"project_panel": {
		"dock": "left",
		"indent_size": 13,
		"auto_fold_dirs": false,
		"default_width": 300,
		"file_icons": true,
		"folder_icons": true,
		"git_status": true,
		"scrollbar": {
			"show": "never"
		}
	},
	"base_keymap": "VSCode",
	"diagnostics": {
		"button": true,
		"include_warnings": true,
		"inline": {
			"enabled": true,
			"update_debounce_ms": 150,
			"padding": 4,
			"min_column": 0,
			"max_severity": null
		}
	},
	"indent_guides": {
		"enabled": true,
		"coloring": "indent_aware"
	},
	"git": {
		"git_gutter": "tracked_files",
		"inline_blame": {
			"enabled": false
		}
	},
	"agent": {
		"profiles": {
			"write-and-apply": {
				"name": "Write and apply",
				"context_servers": {},
				"enable_all_context_servers": true,
				"tools": {
					"copy_path": true,
					"create_directory": true,
					"delete_path": true,
					"diagnostics": true,
					"edit_file": true,
					"fetch": true,
					"list_directory": true,
					"project_notifications": false,
					"move_path": true,
					"now": true,
					"find_path": true,
					"read_file": true,
					"grep": true,
					"terminal": true,
					"thinking": true,
					"web_search": true
				}
			}
		},
		"commit_message_model": {
			"model": "gpt-4.1",
			"provider": "copilot_chat"
		},
		"always_allow_tool_actions": true,
		"inline_assistant_model": {
			"provider": "copilot_chat",
			"model": "gpt-4.1"
		},
		"model_parameters": [],
		"default_model": {
			"provider": "copilot_chat",
			"model": "gpt-4.1"
		}
	},
	"tabs": {
		"file_icons": true,
		"git_status": true,
		"show_diagnostics": "all"
	},
	"vim_mode": true,
	"vim": {
		"toggle_relative_line_numbers": true,
		"use_system_clipboard": "always",
		"use_smartcase_find": true
	},
	"agent_font_size": 16,
	"ui_font_size": 14,
	"buffer_font_size": 14,
	"terminal": {
		"shell": "system",
		"line_height": { "custom": 1.25 },
		"copy_on_select": true,
		"dock": "right",
		"font_size": 12,
		"env": {
			"EDITOR": "zed --wait"
		}
	},
	"file_finder": {
		"modal_max_width": "medium"
	},
	"preview_tabs": {
		"enabled": true,
		"enable_preview_from_file_finder": false,
		"enable_preview_from_code_navigation": false
	},
	"centered_layout": {
		"left_padding": 0.1,
		"right_padding": 0.1
	},
	"outline_panel": {
		"dock": "right"
	},
	"ui_font_family": "Hack Nerd Font Mono",
	"buffer_font_family": "Hack Nerd Font Mono",
	"theme": {
		"mode": "dark",
		"light": "One Light",
		"dark": "Catppuccin Macchiato"
	},
	"search": {
		"whole_word": false,
		"case_sensitive": true,
		"include_ignored": false,
		"regex": false
	},
	"features": {
		"edit_prediction_provider": "copilot"
	},
	"show_edit_predictions": true,
	"collaboration_panel": {
		"button": false
	},
	"icon_theme": "Catppuccin Macchiato",
	"preferred_line_length": 80,
	"soft_wrap": "editor_width",
	"formatter": {
		"language_server": {
			"name": "biome"
		}
	},
	"auto_install_extensions": {
		"catppuccin": true,
		"catppuccin-icons": true,
		"biome": true,
		"html": true,
		"dockerfile": true,
		"docker-compose": true,
		"scss": true,
		"lua": true,
		"astro": true,
		"hyprlang": true
	},
	"edit_predictions": {
		"mode": "eager"
	},
	"code_actions_on_format": {
		"source.fixAll.biome": true,
		"source.organizeImports.biome": true,
		"source.action.useSortedKeys.biome": true
	},
	"file_types": {
		"Hyprland Config": [
			"hyprland.conf",
			"hyprlandd.conf",
			"hyprland.hl",
			"hyprlandd.hl"
		]
	},
	"languages": {
		"SCSS": { "formatter": "auto" },
		"JavaScript": { "formatter": { "language_server": { "name": "biome" } } },
		"TypeScript": { "formatter": { "language_server": { "name": "biome" } } },
		"TSX": { "formatter": { "language_server": { "name": "biome" } } },
		"JSON": { "formatter": { "language_server": { "name": "biome" } } },
		"JSONC": { "formatter": { "language_server": { "name": "biome" } } },
		"CSS": { "formatter": { "language_server": { "name": "biome" } } },
		"QML": {
			"formatter": {
				"external": {
					"command": "sh",
					"arguments": [
						"-c",
						"tmp=$(mktemp --suffix .qml); cat > $tmp; qmlformat $tmp"
					]
				}
			}
		}
	},
	"lsp": {
		"vtsls": {
			"settings": {
				"typescript": {
					"preferences": {
						"importModuleSpecifier": "non-relative"
					}
				}
			}
		},
		"tailwindcss-language-server": {
			"settings": {
				"classAttributes": ["class", "className", "ngClass", "styles"],
				"experimental": {
					"classRegex": [
						"[a-zA-Z]*ClassName='([^']+)'",
						"[a-zA-Z]*ClassName=\"([^\"]+)\"",
						"[a-zA-Z]*ClassName={`([^`]+)`}",
						"[a-zA-Z]*ClassName={.+|\n*}"
					]
				}
			}
		},
		"qml": {
			"binary": {
				"arguments": ["-E"]
			}
		}
	}
}
