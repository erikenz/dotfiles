#!/usr/bin/fish

# Launch an app or focus an existing window matching a pattern
set match_title false
if test (count $argv) -gt 0; and test "$argv[1]" = "--match-title"
    set match_title true
    set argv $argv[2..-1]
end

if test (count $argv) -lt 1
    echo "Usage: launch-or-focus [--match-title] <window-pattern> [launch-command]"
    exit 1
end

set window_pattern $argv[1]
set launch_command $argv[2]

if not set -q argv[2]; or test -z "$launch_command"
    set launch_command "uwsm app -- $window_pattern"
end

# Find window address and its workspace using jq with a case-insensitive regex search
if test "$match_title" = "true"
    set result (hyprctl clients -j | jq -r --arg p "$window_pattern" '
        .[] | 
        select(
            (.class | ascii_downcase | test($p | ascii_downcase)) or 
            (.title | ascii_downcase | test($p | ascii_downcase)) or
            (.initialClass | ascii_downcase | test($p | ascii_downcase))
        ) | 
        .address + " " + .workspace.name
    ' | head -n 1)
else
    set result (hyprctl clients -j | jq -r --arg p "$window_pattern" '
        .[] | 
        select(
            (.class | ascii_downcase | test($p | ascii_downcase)) or 
            (.initialClass | ascii_downcase | test($p | ascii_downcase))
        ) | 
        .address + " " + .workspace.name
    ' | head -n 1)
end


if test -n "$result"; and test "$result" != "null"
    # Split the result into address and workspace
    set parts (string split " " $result)
    set window_address $parts[1]
    set workspace_name $parts[2]

    # Focus the workspace first to ensure it switches screens/workspaces
    hyprctl dispatch "hl.dsp.focus({ workspace = \"$workspace_name\" })"
    # Focus the window
    hyprctl dispatch "hl.dsp.exec_raw(\"focuswindow address:$window_address\")"
else
    # Execute launch command in background
    eval "$launch_command" &
end
