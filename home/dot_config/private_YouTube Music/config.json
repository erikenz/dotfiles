			"enabled": true
		},
		"shortcuts": {
			"enabled": true,
			"overrideMediaKeys": false,
			"global": {
				"previous": "Ctrl+Shift+,",
				"playPause": "Ctrl+Shift+/",
				"next": "Ctrl+Shift+."
			},
			"local": {
				"previous": "",
				"playPause": "",
				"next": ""
			}
		},
		"adblocker": {
			"enabled": false
		},
		"synced-lyrics": {
			"enabled": true
		}
	},
	"__internal__": {
		"migrations": {
			"version": "3.10.0"
		}
