{
	"window-size": {
		"width": 925,
		"height": 1060
	},
	"window-maximized": true,
	"window-position": {
		"x": 0,
		"y": 0
	},
	"url": "https://music.youtube.com/watch?v=1Gb6MIuWpW8&list=RDAMVMEnR3qp_vGUQ&index=0",
	"options": {
