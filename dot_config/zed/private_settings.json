{
	"project_panel": {
		"dock": "left",
		"indent_size": 13,
		"auto_fold_dirs": false
	},
	"diagnostics": {
		"button": true,
		"include_warnings": true,
		"inline": {
			"enabled": true,
			"update_debounce_ms": 150,
			"padding": 4,
			"min_column": 0,
			"max_severity": null
		}
	},
	"agent": {
		"inline_assistant_model": {
			"provider": "copilot_chat",
			"model": "gpt-4.1"
		},
		"model_parameters": [],
		"default_model": {
			"provider": "copilot_chat",
			"model": "gpt-4.1"
		}
	},
	"tabs": {
		"file_icons": true,
		"git_status": true,
		"show_diagnostics": "all"
	},
	"vim_mode": true,
	"vim": {
		"toggle_relative_line_numbers": true,
		"use_system_clipboard": "always",
		"use_smartcase_find": true
	},
	"agent_font_size": 16,
	"ui_font_size": 16,
	"buffer_font_size": 16,
	"terminal": {
		"shell": "system",
		"line_height": { "custom": 1.25 },
		"copy_on_select": true,
		"dock": "right",
		"font_size": 14
	},
	"ui_font_family": "Hack Nerd Font Mono",
	"buffer_font_family": "Hack Nerd Font Mono",
	"theme": {
		"mode": "dark",
		"light": "One Light",
		"dark": "Catppuccin Macchiato"
	},
	"features": {
		"edit_prediction_provider": "copilot"
	},
	"show_edit_predictions": true,
	"collaboration_panel": {
		"button": false
	},
	"icon_theme": "Catppuccin Macchiato",
	"preferred_line_length": 80,
	"soft_wrap": "editor_width",
	"formatter": {
		"language_server": {
			"name": "biome"
		}
	},
	"auto_install_extensions": {
		"catppuccin": true,
		"catppuccin-icons": true,
		"biome": true,
		"html": true,
		"dockerfile": true,
		"docker-compose": true,
		"scss": true,
		"lua": true,
		"astro": true
	},
	"edit_predictions": {
		"mode": "eager"
	},
	"code_actions_on_format": {
		"source.fixAll.biome": true,
		"source.organizeImports.biome": true,
		"source.action.useSortedKeys.biome": true
	},
	"languages": {
		"SCSS": { "formatter": "auto" },
		"JavaScript": { "formatter": { "language_server": { "name": "biome" } } },
		"TypeScript": { "formatter": { "language_server": { "name": "biome" } } },
		"TSX": { "formatter": { "language_server": { "name": "biome" } } },
		"JSON": { "formatter": { "language_server": { "name": "biome" } } },
		"JSONC": { "formatter": { "language_server": { "name": "biome" } } },
		"CSS": { "formatter": { "language_server": { "name": "biome" } } }
	},
	"lsp": {
		"vtsls": {
			"settings": {
				"typescript": {
					"preferences": {
						"importModuleSpecifier": "non-relative"
					}
				}
			}
		},
		"tailwindcss-language-server": {
			"settings": {
				"classAttributes": ["class", "className", "ngClass", "styles"],
				"experimental": {
					"classRegex": [
						"[a-zA-Z]*ClassName='([^']+)'",
						"[a-zA-Z]*ClassName=\"([^\"]+)\"",
						"[a-zA-Z]*ClassName={`([^`]+)`}",
						"[a-zA-Z]*ClassName={.+|\n*}"
					]
				}
			}
		}
	}
}
