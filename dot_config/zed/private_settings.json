// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1"
    },
    "version": "2"
  },
  "base_keymap":"VSCode",
  "icon_theme": "Catppuccin Mocha",
  "terminal": {
    "dock": "right",
    "copy_on_select": true,
    "font_size": 12
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "errors"
  },
  "project_panel": {
    "auto_fold_dirs": false,
    "dock": "left"
  },
  "features": {
    "edit_prediction_provider": "zed"
  },
  "diagnostics": {
    "include_warnings": false,
    "inline": {
      "enabled": false,
      "update_debounce_ms": 150,
      "padding": 4,
      "min_column": 0,
      "max_severity": null
    }
  },
  "relative_line_numbers": true,
  "vim_mode": true,
  "ui_font_size": 14,
  "buffer_font_size": 14,
  "soft_wrap": "editor_width",
  "preferred_line_length": 80,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Mocha"
  },
  "chat_panel": {
    "button": "when_in_call"
  },
  "collaboration_panel": {
    "button": false
  },
  "indent_guides": {
    "enabled": true,
    "active_line_width": 2,
    "coloring": "indent_aware"
  },
  "ui_font_family": "JetBrainsMono Nerd Font",
  "formatter": {
    "language_server": {
      "name": "biome"
    }
  },
  "code_actions_on_format": {
    "source.fixAll.biome": true,
    "source.organizeImports.biome": true,
    "source.action.useSortedKeys.biome": true
  },
  "languages": {
    "SCSS": {
      "formatter": "auto"
    }
    // "JavaScript": {
    //   "formatter": {
    //     "external": {
    //       "command": "prettier",
    //       "arguments": [
    //         "--stdin-filepath",
    //         "{buffer_path}"
    //       ]
    //     }
    //   },
    //   "code_actions_on_format": {
    //     "source.fixAll.eslint": true
    //   }
    // },
    // "TypeScript": {
    //   "formatter": {
    //     "external": {
    //       "command": "prettier",
    //       "arguments": [
    //         "--stdin-filepath",
    //         "{buffer_path}"
    //       ]
    //     }
    //   },
    //   "code_actions_on_format": {
    //     "source.fixAll.eslint": true
    //   }
    // }
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "preferences": {
            "importModuleSpecifier": "non-relative"
          }
        }
      }
    },
    "tailwindcss-language-server": {
      "settings": {
        "classAttributes": [
          "class",
          "className",
          "ngClass",
          "styles"
        ],
        "experimental": {
          "classRegex": [
            "[a-zA-Z]*ClassName='([^']+)'",
            "[a-zA-Z]*ClassName=\"([^\"]+)\"",
            "[a-zA-Z]*ClassName={`([^`]+)`}",
            "[a-zA-Z]*ClassName={.+|\n*}"
          ]
        }
      }
    },
    "biome": {
      "settings": {
        "require_config_file": true
      }
    },
    "prettier": {
      "settings": {
        "require_config_file": true
      }
    }
  }
}
