#!/usr/bin/fish

# Launch a URL as a web app in the default supported browser
if test (count $argv) -lt 1
    echo "Usage: launch-webapp <url> [additional-flags...]"
    exit 1
end

set url $argv[1]
set flags $argv[2..-1]

# Get default web browser desktop file name
set browser (xdg-settings get default-web-browser)

if test -z "$browser"
    set browser "vivaldi-stable.desktop"
end

# Find the executable from the desktop file
set desktop_files ~/.local/share/applications/$browser ~/.nix-profile/share/applications/$browser /usr/share/applications/$browser

set browser_exec ""
for file in $desktop_files
    if test -f $file
        # Extract the Exec line (ignoring parameters like %U)
        set exec_line (grep -m 1 "^Exec=" $file | cut -d= -f2-)
        set parts (string split " " $exec_line)
        set browser_exec $parts[1]
        break
    end
end

if test -z "$browser_exec"
    set browser_exec "vivaldi"
end

# Check if default browser is Chromium-based to use --app mode
switch $browser
    case 'google-chrome*' 'brave*' 'microsoft-edge*' 'opera*' 'vivaldi*' 'helium*' 'chromium*'
        exec uwsm app -- $browser_exec --app="$url" $flags
    case '*'
        # For non-Chromium browsers like Firefox or Zen Browser, use --new-window
        if string match -q "*zen*" $browser_exec; or string match -q "*firefox*" $browser_exec
            exec uwsm app -- $browser_exec --new-window "$url" $flags
        else
            exec uwsm app -- $browser_exec "$url" $flags
        end
end
